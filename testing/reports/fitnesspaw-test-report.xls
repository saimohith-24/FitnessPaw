    <td>1500ms</td>
  </tr>
  <tr>
    <td>MOB-05</td>
    <td>Complete Habit checkbox</td>
    <td>Clicks checkbox list node and confirms strikethrough decoration.</td>
    <td class="pass-badge">PASSED</td>
    <td>1100ms</td>
  </tr>
  <tr class="zebra">
    <td>MOB-06</td>
    <td>Water Intake increment</td>
    <td>Taps cup icon button and validates Datastore state value triggers sync.</td>
    <td class="pass-badge">PASSED</td>
    <td>920ms</td>
  </tr>
  <tr>
    <td>MOB-07</td>
    <td>Sleep tracker logging</td>
    <td>Opens sleep dialog drawer, selects time, and checks log item save.</td>
    <td class="pass-badge">PASSED</td>
    <td>1800ms</td>
  </tr>
  <tr class="zebra">
    <td>MOB-08</td>
    <td>Step sensor calibration</td>
    <td>Simulates walk event and verifies text displays steps count correctly.</td>
    <td class="pass-badge">PASSED</td>
    <td>740ms</td>
  </tr>
  <tr>
    <td>MOB-09</td>
    <td>Profile & Pet renaming</td>
    <td>Toggles fields, saves changes, and checks ViewModel state changes.</td>
    <td class="pass-badge">PASSED</td>
    <td>1300ms</td>
  </tr>
  <tr class="zebra">
    <td>MOB-10</td>
    <td>Log out activity E2E</td>
    <td>Taps sign out, confirms Datastore clears, and returns to Login.</td>
    <td class="pass-badge">PASSED</td>
    <td>1600ms</td>
  </tr>
</table>

<!-- Section 4: Load Testing performance -->
<table>
  <tr>
    <td colspan="5" class="section-header">4. LOAD TESTING PERFORMANCE (k6)</td>
  </tr>
  <tr>
    <th style="width: 80px;">Scenario</th>
    <th style="width: 150px;">Concurrency</th>
    <th style="width: 180px;">Average Latency</th>
    <th style="width: 180px;">P95 Latency SLA</th>
    <th style="width: 150px;" class="text-center">HTTP Error Rate</th>
  </tr>
  <tr>
    <td>Ramp-up Stage</td>
    <td>100 Virtual Users (VUs)</td>
    <td>85ms</td>
    <td class="pass-badge">142ms (&lt; 800ms)</td>
    <td class="text-center">0.0%</td>
  </tr>
  <tr class="zebra">
    <td>Scale-up Stage</td>
    <td>500 Virtual Users (VUs)</td>
    <td>195ms</td>
    <td class="pass-badge">310ms (&lt; 800ms)</td>
    <td class="text-center">0.0%</td>
  </tr>
  <tr>
    <td>Peak Load Stage</td>
    <td>1000 Virtual Users (VUs)</td>
    <td>310ms</td>
    <td class="pass-badge">495ms (&lt; 800ms)</td>
    <td class="text-center">0.04%</td>
  </tr>
</table>

<!-- Section 5: Security scanning audits -->
<table>
  <tr>
    <td colspan="5" class="section-header">5. CODE SECURITY & AUDITING SCANS</td>
  </tr>
