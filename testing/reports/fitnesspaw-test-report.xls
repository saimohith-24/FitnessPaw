   </Row>
   <Row ss:Height="36">
    <Cell ss:StyleID="TestCaseIDOdd"><Data ss:Type="String">TC-API-001</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">Authentication API</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">Auth / Login / SignUp - Register Account</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">Verify database entry creation for signup payload.</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">API server online. Unique email.</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">1. Send POST to /api/auth/signup with {data}.
2. Assert status code 201 and valid payload.</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">Payload: {username: 'user1', email: 'user1@fitpaw.com'}</Data></Cell>
    <Cell ss:StyleID="RowOdd"><Data ss:Type="String">User profile is successfully created in DB and active session token returned.</Data></Cell>
    <Cell ss:StyleID="StatusPassedOdd"><Data ss:Type="String">PASSED</Data></Cell>
   </Row>
   <Row ss:Height="36">
    <Cell ss:StyleID="TestCaseIDEven"><Data ss:Type="String">TC-API-002</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">Habit Tracker API</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">Habit CRUD &amp; Streaks - Create Habit</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">Verify habit creation via POST request endpoint.</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">User logged in.</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">1. POST to /api/habits with title and frequency.
2. Confirm habit ID and creation timestamp.</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">Body: {title: 'Drink water', freq: 'daily'}</Data></Cell>
    <Cell ss:StyleID="RowEven"><Data ss:Type="String">Habit record is created with active status and stored under user profile.</Data></Cell>
    <Cell ss:StyleID="StatusPassedEven"><Data ss:Type="String">PASSED</Data></Cell>
   </Row>
   <Row ss:Height="36">
