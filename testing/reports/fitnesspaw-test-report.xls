xmlns:o="urn:schemas-microsoft-com:office:office"
xmlns:x="urn:schemas-microsoft-com:office:excel"
xmlns="http://www.w3.org/TR/REC-html40">
<head>
<meta http-equiv="Content-type" content="text/html;charset=utf-8" />
<style>
  body { font-family: 'Segoe UI', Tahoma, Arial, sans-serif; }
  table { border-collapse: collapse; margin-bottom: 30px; }
  td, th { border: 1px solid #cbd5e1; padding: 10px 12px; text-align: left; font-size: 11pt; }
  th { background-color: #1e293b; color: #ffffff; font-weight: bold; font-size: 12pt; }
  .section-header { background-color: #4f46e5; color: #ffffff; font-size: 14pt; font-weight: bold; padding: 12px; }
  .title-header { background-color: #0f172a; color: #ffffff; font-size: 18pt; font-weight: bold; padding: 15px; text-align: center; }
  .zebra { background-color: #f8fafc; }
  .pass-badge { background-color: #d1fae5; color: #065f46; font-weight: bold; text-align: center; }
  .fail-badge { background-color: #fee2e2; color: #991b1b; font-weight: bold; text-align: center; }
  .info-badge { background-color: #e0f2fe; color: #075985; font-weight: bold; text-align: center; }
  .text-bold { font-weight: bold; }
  .text-center { text-align: center; }
</style>
</head>
<body>

<table>
  <!-- Main Title -->
  <tr>
    <td colspan="5" class="title-header">FITNESSPAW - QA TEST EXECUTION MASTER REPORT</td>
  </tr>
  <tr>
    <td colspan="2" class="text-bold">Date of Run:</td>
    <td colspan="3">2026-06-23 09:50:00 (UTC)</td>
  </tr>
  <tr>
    <td colspan="2" class="text-bold">Environment:</td>
    <td colspan="3">CI/CD Enterprise Pipeline (GitHub Actions)</td>
  </tr>
  <tr>
    <td colspan="2" class="text-bold">Overall Pass Rate:</td>
    <td colspan="3" class="pass-badge">100% (34 / 34 Tests Passed)</td>
  </tr>
</table>

<!-- Section 1: API Integration Tests -->
<table>
  <tr>
    <td colspan="5" class="section-header">1. API INTEGRATION TESTS</td>
  </tr>
  <tr>
    <th style="width: 50px;">ID</th>
    <th style="width: 250px;">Test Name</th>
    <th style="width: 350px;">Assertion / Verification Detail</th>
    <th style="width: 80px;" class="text-center">Status</th>
    <th style="width: 100px;">Duration</th>
  </tr>
  <tr>
    <td>API-01</td>
    <td>Signup Validation API</td>
    <td>Verifies username limits, email format, password safety, and default pet codes.</td>
    <td class="pass-badge">PASSED</td>
    <td>8ms</td>
  </tr>
  <tr class="zebra">
    <td>API-02</td>
    <td>Login Authentication API</td>
    <td>Validates matching credential tokens and return payload schemas.</td>
    <td class="pass-badge">PASSED</td>
    <td>4ms</td>
  </tr>
  <tr>
    <td>API-03</td>
    <td>Forgot Password API</td>
    <td>Verifies validation checks for registered email accounts.</td>
    <td class="pass-badge">PASSED</td>
    <td>3ms</td>
  </tr>
  <tr class="zebra">
    <td>API-04</td>
    <td>Habit CRUD Operations API</td>
    <td>Validates creating, updating, completing, and deleting custom habit records.</td>
    <td class="pass-badge">PASSED</td>
    <td>11ms</td>
  </tr>
  <tr>
    <td>API-05</td>
    <td>Water Tracking Operations API</td>
    <td>Verifies water counters, increments, and daily limit boundaries.</td>
    <td class="pass-badge">PASSED</td>
    <td>5ms</td>
  </tr>
  <tr class="zebra">
    <td>API-06</td>
    <td>Sleep Duration API</td>
    <td>Verifies wake/sleep duration arithmetic calculations and logging.</td>
    <td class="pass-badge">PASSED</td>
    <td>6ms</td>
  </tr>
  <tr>
    <td>API-07</td>
    <td>Step Tracking API</td>
    <td>Validates step count computations relative to step sensor baselines.</td>
    <td class="pass-badge">PASSED</td>
    <td>7ms</td>
  </tr>
  <tr class="zebra">
    <td>API-08</td>
    <td>Analytics API</td>
    <td>Verifies aggregation logic for step averages and weight logs.</td>
    <td class="pass-badge">PASSED</td>
    <td>9ms</td>
  </tr>
</table>

<!-- Section 2: Selenium Web UI Tests -->
<table>
  <tr>
    <td colspan="5" class="section-header">2. SELENIUM E2E WEBSITE TESTS</td>
  </tr>
  <tr>
    <th style="width: 50px;">ID</th>
    <th style="width: 250px;">Test Name / Flow</th>
    <th style="width: 350px;">E2E UI Action flow details</th>
    <th style="width: 80px;" class="text-center">Status</th>
    <th style="width: 100px;">Duration</th>
  </tr>
  <tr>
    <td>WEB-01</td>
    <td>User Signup UI Flow</td>
    <td>Enters inputs on /signup form and redirects successfully to /dashboard.</td>
    <td class="pass-badge">PASSED</td>
    <td>1450ms</td>
  </tr>
  <tr class="zebra">
    <td>WEB-02</td>
    <td>User Login UI Flow</td>
    <td>Logs in on landing page and redirects to main dashboard panels.</td>
    <td class="pass-badge">PASSED</td>
    <td>1210ms</td>
  </tr>
  <tr>
    <td>WEB-03</td>
    <td>Dashboard Widgets Render</td>
    <td>Verifies steps cards, water cups, and pet visual graphics displays.</td>
    <td class="pass-badge">PASSED</td>
    <td>540ms</td>
  </tr>
  <tr class="zebra">
    <td>WEB-04</td>
    <td>Analytics Page & Forms</td>
    <td>Validates step history canvas and weight logging input forms.</td>
    <td class="pass-badge">PASSED</td>
    <td>890ms</td>
  </tr>
  <tr>
    <td>WEB-05</td>
    <td>Habit Checklist Creation</td>
    <td>Inputs title, clicks add, and verifies checklist DOM updates.</td>
    <td class="pass-badge">PASSED</td>
    <td>980ms</td>
  </tr>
  <tr class="zebra">
    <td>WEB-06</td>
    <td>Water Intake Button Increment</td>
    <td>Clicks increment and asserts counter value increments by +1.</td>
    <td class="pass-badge">PASSED</td>
    <td>670ms</td>
  </tr>
  <tr>
    <td>WEB-07</td>
    <td>Theme Switcher toggle</td>
    <td>Clicks dark mode toggle and verifies html data-theme changes to 'dark'.</td>
    <td class="pass-badge">PASSED</td>
    <td>420ms</td>
  </tr>
  <tr class="zebra">
    <td>WEB-08</td>
    <td>User Logout Flow</td>
    <td>Clicks exit button and verifies redirection back to welcome screen.</td>
    <td class="pass-badge">PASSED</td>
    <td>810ms</td>
  </tr>
</table>

<!-- Section 3: Appium Android E2E Tests -->
<table>
  <tr>
    <td colspan="5" class="section-header">3. APPIUM MOBILE ANDROID E2E TESTS</td>
  </tr>
  <tr>
    <th style="width: 50px;">ID</th>
    <th style="width: 250px;">Test Name / Activity</th>
    <th style="width: 350px;">Android Activity UI Action validation</th>
    <th style="width: 80px;" class="text-center">Status</th>
    <th style="width: 100px;">Duration</th>
  </tr>
  <tr>
    <td>MOB-01</td>
    <td>App Launch & Splash Activity</td>
    <td>Checks logo graphics on splash launch transitions.</td>
    <td class="pass-badge">PASSED</td>
    <td>2100ms</td>
  </tr>
  <tr class="zebra">
    <td>MOB-02</td>
    <td>Mobile User Signup activity</td>
    <td>Inputs forms, selects pet icon, and loads dashboard activity.</td>
    <td class="pass-badge">PASSED</td>
    <td>3100ms</td>
  </tr>
  <tr>
    <td>MOB-03</td>
    <td>Mobile User Login activity</td>
    <td>Fills email/password inputs, clicks submit, and confirms token storage.</td>
    <td class="pass-badge">PASSED</td>
    <td>2400ms</td>
  </tr>
  <tr class="zebra">
    <td>MOB-04</td>
    <td>Add Habit Checklist</td>
    <td>Clicks '+' button, types title, and checks Compose list item view.</td>
